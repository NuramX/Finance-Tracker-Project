generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ตารางหมวดหมู่
model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  icon         String?
  transactions Transaction[]
}

// ตารางรายการใช้จ่าย
model Transaction {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(12, 2) // ใช้ Decimal เพื่อความแม่นยำเรื่องเงิน
  description String
  date        DateTime @default(now())
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
}